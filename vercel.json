{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/documents",
      "destination": "/"
    },
    {
      "source": "/documents/:id",
      "destination": "/"
    },
    {
      "source": "/sop",
      "destination": "/"
    },
    {
      "source": "/standar",
      "destination": "/"
    },
    {
      "source": "/standards",
      "destination": "/"
    },
    {
      "source": "/services",
      "destination": "/"
    },
    {
      "source": "/library",
      "destination": "/"
    },
    {
      "source": "/library/:id",
      "destination": "/"
    },
    {
      "source": "/kpi",
      "destination": "/"
    },
    {
      "source": "/dashboard-kpi",
      "destination": "/"
    },
    {
      "source": "/dashboard-k3",
      "destination": "/"
    },
    {
      "source": "/kpi-input",
      "destination": "/"
    },
    {
      "source": "/input-update-data",
      "destination": "/"
    },
    {
      "source": "/service-mapping",
      "destination": "/"
    },
    {
      "source": "/admin",
      "destination": "/"
    },
    {
      "source": "/admin/upload",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/app.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/knowledge-features.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/kpi-dashboard.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
